{
    "name": "draw-axis-p5js",
    "version": "1.0.0",
    "description": "package for drawing coordinate axes in p5.js",
    "main": "dist/draw-axis-p5js.js",
    "types": "dist/draw-axis-p5js.d.ts",
    "type": "commonjs",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/draw-axis-p5js.d.ts",
            "require": "./dist/draw-axis-p5js.js",
            "default": "./dist/draw-axis-p5js.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc -p .",
        "pretest": "tsc -p .",
        "test": "node --test dist/draw-axis-p5js.test.js",
        "prepublishOnly": "npm run build && node --test dist/draw-axis-p5js.test.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/damiansire/p5-toolkit.git",
        "directory": "packages/draw-axis"
    },
    "keywords": [
        "p5js",
        "p5.js",
        "draw-axis",
        "axis",
        "draw",
        "processing",
        "processingJs"
    ],
    "author": "Damian Sire <damiansire@gmail.com>",
    "license": "MIT",
    "peerDependencies": {
        "p5": "^1.0.0"
    },
    "bugs": {
        "url": "https://github.com/damiansire/p5-toolkit/issues"
    },
    "homepage": "https://github.com/damiansire/p5-toolkit/tree/main/packages/draw-axis#readme"
}
